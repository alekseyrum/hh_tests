{
 "name": "Text paster",
 "description": "Copies prepared strings into page without loosing focus",
 "version": "1.0",
 "manifest_version": 3,
 "icons": {
	 "16":"icons/icon_paster_16.png",
 	"32":"icons/icon_paster_32.png",
 	"48":"icons/icon_paster_48.png",
    "64":"icons/icon_paster_64.png",
 	"128":"icons/icon_paster_128.png"	
 },
 "action": {
 	"default_popup":"popup.html"
 },
 "permissions": ["scripting", "activeTab" , "notifications" ],
 "background":{}
}